<launch>

  <!--- Teleop Joystick -->
  <node pkg="teleop_twist_joy" type="teleop_node" name="teleop_node" output="screen">
    <param name="scale_angular" value="0.5"/>
    <param name="scale_linear" value="0.3"/>
  </node>

  <node pkg="joy" type="joy_node" name="joystick" output="screen" >
    <param name="coalesce_interval" value="0.1" />
  </node>

</launch>
